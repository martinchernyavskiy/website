---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoDeck from '../components/PhotoDeck'; 
import DailyTunes from '../components/DailyTunes';
import TechStack from '../components/TechStack';

const experiences = [
  {
    title: "Undergraduate Researcher, Sirius DB",
    company: "UW–Madison Systems Lab (NVIDIA Collaborative)",
    date: "Jan 2026 – Present",
    description: "Developing C++ query execution pipelines for an NVIDIA-collaborative GPU-accelerated SQL engine, optimizing analytical workload performance using the RAPIDS ecosystem."
  },
  {
    title: "Visiting Researcher, Distributed Data Systems",
    company: "Peking University, Beijing",
    date: "Jun 2025 – Aug 2025",
    description: "Engineered a C++ analytical storage prototype migrating from row-oriented to vectorized execution, achieving a 3x improvement in query scan performance on TPC-H benchmarks."
  },
  {
    title: "Undergraduate Researcher, Info Theory",
    company: "UW–Madison Department of Mathematics",
    date: "Aug 2024 – May 2025",
    description: "Applied algorithmic information theory and Kolmogorov complexity to analyze theoretical compression limits relevant to database storage systems."
  },
  {
    title: "Software Engineer",
    company: "Cardinal Trading Group",
    date: "Sep 2024 – Jan 2025",
    description: "Built high-performance Python backtesting and ETL infrastructure for a quantitative trading organization, reducing execution time from 3 minutes to under 30 seconds."
  }
];

const contactLinks = [
  { label: 'Email Me', href: 'mailto:martin.chernyavskiy@proton.me' },
  { label: 'GitHub', href: 'https://github.com/martinchernyavskiy' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/martin-chernyavskiy' }
];
---

<BaseLayout title="Martin Chernyavskiy | Systems & Database Engineer">
  
  <div class="mt-10 relative">
    
    <section class="space-y-12 relative z-10 pb-2">
      <h1 class="text-4xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50">
        Hello, I'm Martin Chernyavskiy <span class="animate-wave inline-block">👋</span>
      </h1>

      <div class="grid grid-cols-1 md:grid-cols-[300px_1fr] items-center w-full gap-12 md:gap-[120px]">
        <div class="relative z-10 flex justify-center md:justify-start md:ml-0 lg:ml-4 p-4 bg-sky-50 dark:bg-sky-950 rounded-2xl">
          <PhotoDeck client:load />
        </div>

        <div class="min-w-0 w-full max-w-sm mx-auto md:mx-0">
          <DailyTunes client:load />
        </div>
      </div>

      <div class="space-y-6 max-w-2xl">
        <p class="text-lg text-sky-900/90 dark:text-sky-100/90 leading-relaxed">
          I'm a <span class="font-bold text-sky-600 dark:text-sky-400">Computer Science student</span> at the University of Wisconsin–Madison.
          My interests center on database internals, distributed systems, and hardware-level performance optimization.
          I focus on engineering scalable backend infrastructure, ranging from columnar execution engines to fault-tolerant data pipelines.
        </p>
        
        <div class="flex flex-wrap gap-4 pt-0">
          {contactLinks.map((link) => (
            <div class="claw-container">
              <div class="shake-unit">

<a 
                  href={link.href}
                  target={link.label !== 'Email Me' ? "_blank" : undefined}
                  class="relative z-[2] px-5 py-2.5 rounded-xl border border-sky-200 dark:border-sky-800 
                         hover:border-sky-400 dark:hover:border-sky-500
                         hover:text-sky-600 dark:hover:text-sky-300
                         transition-all duration-300 text-sm font-bold 
                         text-sky-900 dark:text-sky-100 bg-sky-50 dark:bg-sky-950 inline-block"
                >
                  {link.label}
                </a>

              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="experience" class="pt-4 pb-4 border-t border-sky-100 dark:border-sky-900 scroll-mt-24 relative z-10">
      <h2 class="text-2xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50 mb-3">Experience</h2>
      <div class="space-y-4">
        {experiences.map((exp) => (
          <div class="group border border-sky-200 dark:border-sky-800 rounded-2xl p-6 hover:bg-white dark:hover:bg-sky-900/30 hover:border-sky-400 dark:hover:border-sky-500 hover:shadow-xl hover:shadow-sky-500/5 transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-1">
              <h3 class="text-lg font-bold tracking-tight text-sky-950 dark:text-sky-100">
                {exp.title}
              </h3>
              <span class="text-sm text-slate-500 dark:text-slate-400 font-semibold">
                {exp.date}
              </span>
            </div>
            
            <p class="text-sky-600 dark:text-sky-400 text-sm font-bold mb-3">
              {exp.company}
            </p>
            
            <p class="text-sky-800/90 dark:text-sky-200/90 leading-relaxed text-sm">
              {exp.description}
            </p>
          </div>
        ))}
      </div>
    </section>
    <!--
    <section id="skills" class="pt-4 pb-6 border-t border-sky-100 dark:border-sky-900 scroll-mt-24 relative z-10">
      <h2 class="text-2xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50 mb-3">Skills & Technologies</h2>
      <div class="pt-2">
        <TechStack client:load />
      </div>
    </section>
  -->
    <section class="pt-5 border-t border-sky-100 dark:border-sky-900 relative z-10 pb-4">
      <h2 class="text-2xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50 mb-5">Beyond Code</h2>
      <div class="flex flex-wrap gap-3">

        <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/onmwuuox.json" trigger="loop" state="hover-jump-roll" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Traveling</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">Always drawn to new places and the stories that come with them.</p>
          </div>
        </div>
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/rpviwvwn.json" trigger="loop" stroke="bold" state="loop-rotate" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Languages</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">Fascinated by how language shapes the way people think.</p>
          </div>
        </div>
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/jdgfsfzr.json" trigger="loop" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Meeting People</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">Energized by conversations with people from different walks of life.</p>
          </div>
        </div>
        <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/gcupmfyg.json" trigger="loop" stroke="bold" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Music</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">A constant companion for deep work, travel, and everything in between.</p>
          </div>
        </a>
        <a href="/bookshelf" class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/rrbmabsx.json" trigger="loop" stroke="bold" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Reading</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">Drawn to both technical depth and stories that expand perspective.</p>
          </div>
        </a>
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-sky-100 dark:border-sky-900 hover:border-sky-300 dark:hover:border-sky-700 hover:bg-white dark:hover:bg-sky-900/20 transition-all duration-300 w-full sm:w-[calc(50%-0.375rem)]">
          <lord-icon src="https://cdn.lordicon.com/jhiqqftv.json" trigger="loop" stroke="bold" colors="primary:#0ea5e9,secondary:#7dd3fc" style="width:28px;height:28px"></lord-icon>
          <div class="min-w-0">
            <p class="text-sm font-bold text-sky-950 dark:text-sky-100 leading-tight">Cooking</p>
            <p class="text-xs text-sky-700 dark:text-sky-400/60 leading-tight mt-0.5">Finding creativity and calm in cooking something from scratch.</p>
          </div>
        </div>
      </div>
    </section>




  </div>
</BaseLayout>