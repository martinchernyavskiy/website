---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookshelfComponent from '../components/Bookshelf';
---

<BaseLayout title="Bookshelf | Martin Chernyavskiy">
  <div class="mt-10 space-y-8 relative z-10">

    <div class="space-y-2 max-w-2xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50">
        Bookshelf
      </h1>
      <p class="text-lg text-sky-900/80 dark:text-sky-100/70 leading-relaxed">
        Books I've read and books waiting on the shelf. Technical above, everything else below.
        Click a spine to open.
      </p>
    </div>

    <BookshelfComponent client:visible />

  </div>
</BaseLayout>