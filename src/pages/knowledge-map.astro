---
import BaseLayout from '../layouts/BaseLayout.astro';
import RandomCard from '../components/RandomCard';
---

<BaseLayout title="Knowledge Map | Martin Chernyavskiy">
  <div class="mt-10 relative z-10 space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div class="space-y-3 max-w-2xl">
        <div class="flex items-center gap-3">
          <h1 class="text-4xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50">
            Knowledge Map
          </h1>
          <span class="text-[9px] font-mono font-bold uppercase tracking-widest px-2 py-0.5 rounded border border-sky-300 dark:border-sky-700 text-sky-500 dark:text-sky-400 self-center">
            Coming Soon
          </span>
        </div>
        <p class="text-lg text-sky-900/80 dark:text-sky-100/70 leading-relaxed max-w-xl">
          An interactive graph of concepts and technologies, connected across courses and linked to Anki flashcards. Each node is a concept — edges encode prerequisites and relationships. Grows as the decks grow.
        </p>
      </div>
      <div class="flex-shrink-0">
        <RandomCard client:load />
      </div>
    </div>

    <div class="border-t border-sky-100 dark:border-sky-900 pt-10">
      <div class="rounded-2xl border border-dashed border-sky-200 dark:border-sky-800 bg-sky-50/30 dark:bg-sky-900/10 flex flex-col items-center justify-center gap-6 py-0 px-6 text-center" style="min-height: 520px;">

        <svg width="260" height="200" viewBox="0 0 260 200" fill="none" class="text-sky-300/70 dark:text-sky-700/70 mt-10">
          <circle cx="38"  cy="100" r="18" stroke="currentColor" stroke-width="1.4" />
          <circle cx="130" cy="30"  r="18" stroke="currentColor" stroke-width="1.4" />
          <circle cx="222" cy="100" r="18" stroke="currentColor" stroke-width="1.4" />
          <circle cx="130" cy="170" r="18" stroke="currentColor" stroke-width="1.4" />
          <circle cx="130" cy="100" r="18" stroke="currentColor" stroke-width="1.4" stroke-dasharray="4 3" />
          <circle cx="75"  cy="52"  r="12" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
          <circle cx="185" cy="52"  r="12" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
          <circle cx="75"  cy="148" r="12" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
          <circle cx="185" cy="148" r="12" stroke="currentColor" stroke-width="1.2" opacity="0.6" />
          <line x1="55"  y1="91"  x2="113" y2="40"  stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="55"  y1="109" x2="113" y2="160" stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="147" y1="40"  x2="205" y2="91"  stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="147" y1="160" x2="205" y2="109" stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="148" y1="100" x2="204" y2="100" stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="56"  y1="100" x2="112" y2="100" stroke="currentColor" stroke-width="1"   stroke-dasharray="3 2.5" />
          <line x1="86"  y1="58"  x2="112" y2="88"  stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.5" />
          <line x1="86"  y1="142" x2="112" y2="112" stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.5" />
          <line x1="174" y1="58"  x2="148" y2="88"  stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.5" />
          <line x1="174" y1="142" x2="148" y2="112" stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.5" />
          <line x1="63"  y1="60"  x2="73"  y2="88"  stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.4" />
          <line x1="63"  y1="140" x2="73"  y2="112" stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.4" />
          <line x1="197" y1="60"  x2="187" y2="88"  stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.4" />
          <line x1="197" y1="140" x2="187" y2="112" stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" opacity="0.4" />
        </svg>

        <div class="space-y-2">
          <p class="text-sm font-mono font-bold uppercase tracking-widest text-sky-400 dark:text-sky-600">
            Under Construction
          </p>
          <p class="text-xs text-sky-500/60 dark:text-sky-500/40 max-w-sm">
            Check back once more Anki decks are built out across courses.
          </p>
        </div>

        <a
          href="/classes"
          class="mb-10 inline-flex items-center gap-1.5 text-[10px] font-mono font-bold uppercase tracking-widest text-sky-500 dark:text-sky-400 hover:text-sky-600 dark:hover:text-sky-300 transition-colors"
        >
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <path d="M8 5H2M4.5 2.5L2 5l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          View courses and Anki decks
        </a>
      </div>
    </div>

  </div>
</BaseLayout>