---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeMapGraph from '../components/KnowledgeMap';
import RandomCard from '../components/RandomCard';
---

<BaseLayout title="Knowledge Map | Martin Chernyavskiy">
  <div class="mt-10 relative z-10 space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div class="space-y-3 max-w-2xl">
        <h1 class="text-4xl font-extrabold tracking-tight text-sky-950 dark:text-sky-50">
          Knowledge Map
        </h1>
        <p class="text-lg text-sky-900/80 dark:text-sky-100/70 leading-relaxed max-w-xl">
          A visual map of concepts covered across my CS coursework, organized by topic and connected by how ideas build on each other. Click any node to browse its flashcards. Filter by group or search to navigate.
        </p>
      </div>
      <div class="flex-shrink-0">
        <RandomCard client:load />
      </div>
    </div>

    <div class="border-t border-sky-100 dark:border-sky-900 pt-6">
      <KnowledgeMapGraph client:load />
    </div>

  </div>
</BaseLayout>